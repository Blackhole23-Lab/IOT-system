// Prisma schema for IOT-System
// SQLite - zero config, single file, easy deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  role        String   @default("student") // "teacher" | "student" | "admin"
  name        String
  email       String   @default("")
  permissions String   @default("[]") // JSON array e.g. ["teach:create","exam:grade"]
  createdAt   DateTime @default(now())

  // Relations
  attendances       Attendance[]
  submissions       Submission[]
  examsCreated      Exam[]
  teacherClassrooms Classroom[]        @relation("TeacherClassrooms")
  studentClassrooms ClassroomStudent[] @relation("StudentClassrooms")
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String   // "teach" | "test"
  teacherId String
  state     String   @default("{}") // JSON: pdfUrl, currentSlide, etc.
  createdAt DateTime @default(now())
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  duration    Int      // minutes
  totalScore  Int      @default(0)
  questionIds String   // JSON array of question IDs
  status      String   @default("draft") // "draft" | "active" | "ended"
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())

  submissions Submission[]
}

model Question {
  id           String @id @default(cuid())
  type         String // "single" | "multiple" | "judge" | "code" | "essay"
  questionText String
  options      String @default("[]") // JSON array
  answer       String // JSON or plain string
  score        Int
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  answers     String   @default("{}") // JSON: { [qid]: { answer, score, maxScore } }
  score       Int      @default(0)
  totalScore  Int      @default(0)
  status      String   @default("pending") // "pending" | "completed"
  submittedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  exam Exam @relation(fields: [examId], references: [id])

  @@unique([userId, examId])
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  roomCode  String
  date      String   // YYYY-MM-DD
  joinedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, roomCode, date])
}

// Classroom: a teacher's class group containing multiple students
model Classroom {
  id        String   @id @default(cuid())
  name      String   // e.g. "计算机网络 2024级1班"
  teacherId String   // owner teacher's User.id
  teacher   User     @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  members ClassroomStudent[]
}

// Many-to-many: Classroom <-> Student User
model ClassroomStudent {
  id          String    @id @default(cuid())
  classroomId String
  studentId   String
  joinedAt    DateTime  @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation("StudentClassrooms", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
}
