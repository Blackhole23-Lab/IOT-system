# 在线考试系统 - 环境变量配置示例

# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env

# ==========================================
# 应用配置
# ==========================================

# 应用环境：development 或 production
APP_ENV=production

# 应用名称
APP_NAME="Online Exam System"

# 应用URL（生产环境改为实际域名）
APP_URL=http://localhost:8080

# ==========================================
# PHP配置
# ==========================================

# 时区设置
PHP_TIMEZONE=Asia/Shanghai

# 内存限制
PHP_MEMORY_LIMIT=256M

# 文件上传大小限制
PHP_UPLOAD_MAX_FILESIZE=10M
PHP_POST_MAX_SIZE=10M

# ==========================================
# 数据库配置
# ==========================================

# 数据库类型：sqlite, mysql, pgsql
DB_TYPE=sqlite

# SQLite配置（DB_TYPE=sqlite时使用）
DB_PATH=/var/www/html/data/exam_system.db

# MySQL配置（DB_TYPE=mysql时使用）
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=exam_system
# DB_USER=exam_user
# DB_PASSWORD=secure_password

# PostgreSQL配置（DB_TYPE=pgsql时使用）
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=exam_system
# DB_USER=exam_user
# DB_PASSWORD=secure_password

# ==========================================
# Session配置
# ==========================================

# Session存储路径
SESSION_SAVE_PATH=/var/www/html/sessions

# Session过期时间（秒）
SESSION_LIFETIME=3600

# ==========================================
# 安全配置
# ==========================================

# 应用密钥（用于加密，请修改为随机字符串）
APP_KEY=change-this-to-random-string-32-chars

# 是否启用HTTPS（如果使用反向代理HTTPS，设置为true）
FORCE_HTTPS=false

# 允许的域名（CORS配置）
ALLOWED_ORIGINS=http://localhost:8080

# ==========================================
# 邮件配置（可选）
# ==========================================

# SMTP服务器
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@example.com
# MAIL_PASSWORD=your-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@example.com
# MAIL_FROM_NAME="Exam System"

# ==========================================
# 日志配置
# ==========================================

# 日志级别：debug, info, warning, error
LOG_LEVEL=warning

# 日志路径
LOG_PATH=/var/www/html/logs

# ==========================================
# 备份配置
# ==========================================

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 备份路径（宿主机路径）
BACKUP_PATH=/opt/exam-backup/backups

# ==========================================
# Docker配置
# ==========================================

# 容器名称
CONTAINER_NAME=exam-system

# 宿主机端口
HOST_PORT=8080

# 容器内端口
CONTAINER_PORT=80

# ==========================================
# 资源限制
# ==========================================

# CPU限制（核心数）
CPU_LIMIT=1.0
CPU_RESERVATION=0.5

# 内存限制
MEMORY_LIMIT=512M
MEMORY_RESERVATION=256M
